{
  "manifest_version": 3,
  "name": "File Download Manager",
  "author": "Awan Digitals",
  "version": "26.4.11",
  "description": "An extension to intercept downloads and send them to the File Download Manager desktop application.",
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "downloads",
    "cookies",
    "declarativeNetRequest",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:5050/*",
    "http://127.0.0.1:5050/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html",
    "default_title": "File Download Manager is Active"
  }
}
